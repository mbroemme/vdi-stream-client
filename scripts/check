#!/bin/bash

set -euo pipefail

readonly project_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
cd "${project_root}"

clang_format="${CLANG_FORMAT:-}"
if [[ -z "${clang_format}" ]]; then
	for candidate in clang-format-22 clang-format; do
		if command -v "${candidate}" >/dev/null 2>&1; then
			clang_format="${candidate}"
			break
		fi
	done
fi

if [[ -z "${clang_format}" ]] || ! command -v "${clang_format}" >/dev/null 2>&1; then
	printf 'No clang-format found. Set CLANG_FORMAT to its executable name or path.\n' >&2
	exit 1
fi

for command in git shellcheck; do
	if ! command -v "${command}" >/dev/null 2>&1; then
		printf 'Required command not found: %s\n' "${command}" >&2
		exit 1
	fi
done

printf 'Checking shell scripts...\n'
shell_scripts=(
	scripts/check
	scripts/check-comment-spacing
	tools/parsec-login
)
sh -n autogen.sh
bash -n "${shell_scripts[@]}"
shellcheck -S error autogen.sh "${shell_scripts[@]}"

printf 'Checking tracked text whitespace...\n'
if git grep -nI '[[:blank:]]$' -- .; then
	printf 'Trailing whitespace found.\n' >&2
	exit 1
fi

printf 'Checking C formatting...\n'
mapfile -t sources < <(git ls-files 'src/*.c' 'src/*.h' 'include/*.h')
if ((${#sources[@]} == 0)); then
	printf 'No C sources found.\n' >&2
	exit 1
fi
scripts/check-comment-spacing "${sources[@]}"
"${clang_format}" --dry-run --Werror "${sources[@]}"

printf 'All source checks passed.\n'
